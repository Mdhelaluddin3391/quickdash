# Example environment variables for quickdash
# Copy this to .env and update values before running locally or in Docker

# Django
SECRET_KEY=changeme
DEBUG=True

# Database (Postgres/PostGIS)
DB_NAME=quickdash_db
DB_USER=quickdash_user
DB_PASSWORD=quickdash_password
DB_HOST=127.0.0.1
DB_PORT=5432
# Alternatively set DATABASE_URL for 12-factor style
# DATABASE_URL=postgres://quickdash_user:quickdash_password@127.0.0.1:5432/quickdash_db

# Redis
REDIS_URL=redis://127.0.0.1:6379

# Third party keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
FIREBASE_CREDENTIALS_PATH=

# Business constants
BASE_DELIVERY_FEE=20.00
FEE_PER_KM=5.00
MIN_DELIVERY_FEE=20.00
MAX_DELIVERY_FEE=100.00
ORDER_CANCELLATION_WINDOW=300
